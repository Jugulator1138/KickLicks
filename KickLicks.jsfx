i = 0;
while (i < max_disp) (
  bx = 15 + i * (box_sz + box_gp);
  i == pattern_pos ? gfx_set(0.545, 0.227, 0.118, 1) : gfx_set(0.133, 0.122, 0.102, 1);
  gfx_rect(bx, box_y, box_sz, box_sz);
  gfx_set(0.227, 0.208, 0.188, 1);
  gfx_rect(bx, box_y, box_sz, 1); gfx_rect(bx, box_y + box_sz - 1, box_sz, 1);
  gfx_rect(bx, box_y, 1, box_sz); gfx_rect(bx + box_sz - 1, box_y, 1, box_sz);
  i < note_list_len ? (
    i == pattern_pos ? gfx_set(0, 0, 0, 1) : gfx_set(0.361, 0.322, 0.282, 1);
    gfx_x = bx + 3; gfx_y = box_y + 6;
    gui_nn(200[i] % 12);
  );
  i += 1;
);

