// Mode radio (slider7, 0-4)
i = 0;
while (i < 5) (
  bx = 15 + i * 52;
  slider7 == i ? gfx_set(0.545, 0.227, 0.118, 1) : gfx_set(0.133, 0.122, 0.102, 1);
  gfx_rect(bx, 149, 50, 16);
