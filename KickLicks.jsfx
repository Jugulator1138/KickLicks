  slider7 == i ? gfx_set(0.910, 0.835, 0.690, 1) : gfx_set(0.361, 0.322, 0.282, 1);
  gfx_setfont(4); gfx_y = 152;
  i == 0 ? ( gfx_x = bx + 16; gfx_drawstr("UP"); ) :
  i == 1 ? ( gfx_x = bx + 10; gfx_drawstr("DOWN"); ) :
  i == 2 ? ( gfx_x = bx + 10; gfx_drawstr("PEND"); ) :
  i == 3 ? ( gfx_x = bx + 10; gfx_drawstr("RAND"); ) :
  i == 4 ? ( gfx_x = bx + 16; gfx_drawstr("R5"); );
  i += 1;
);
click && mouse_y >= 149 && mouse_y < 165 ? (
  i = 0;
  while (i < 5) (
    bx = 15 + i * 52;
    mouse_x >= bx && mouse_x < bx + 50 ? ( slider7 = i; sliderchange(slider7); );
    i += 1;
  );
);

